        "    'Precio': [round(random.uniform(50, 1500), 2) for _ in range(10)],\n",
        "    'Stock': [random.randint(10, 100) for _ in range(10)]\n",
        "}\n",
        "\n",
        "# Crear el DataFrame\n",
        "df_productos = pd.DataFrame(data)"
